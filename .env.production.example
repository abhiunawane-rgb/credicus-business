# Copy to your hosting provider as environment variables (do NOT commit real values)

# Required — use a long random string (32+ characters)
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# Set to true when your site uses HTTPS (recommended on cPanel after SSL is enabled).
# Required if the host does not send x-forwarded-proto: https to Node.
COOKIE_SECURE="true"

# Required for contact form, uploads, admin user management
# Use a hosted PostgreSQL URL (Neon, Supabase, Railway, Render, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/recruitment_crm?schema=public"

# Optional — set by most hosts automatically
NODE_ENV="production"
