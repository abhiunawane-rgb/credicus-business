{
  "name": "credicus-business",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/dev-clean.ps1",
    "start:demo": "powershell -ExecutionPolicy Bypass -File scripts/dev-clean.ps1",
    "build": "prisma generate && next build",
    "start": "node app.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:setup": "prisma db push && tsx prisma/seed.ts",
    "cpanel:diagnose": "node scripts/cpanel-diagnose.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.4",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  }
}
