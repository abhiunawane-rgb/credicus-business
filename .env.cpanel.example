# cPanel Node.js App — Environment Variables
# Copy each NAME=VALUE into cPanel → Setup Node.js App → Environment Variables
# Do NOT upload this file with real secrets.

# Required — login sessions (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Required
NODE_ENV=production

# HTTPS enabled on cPanel (SSL Active) — use this:
COOKIE_SECURE=true

# If testing on HTTP only (no SSL yet):
# ALLOW_INSECURE_COOKIES=true

# REQUIRED for permanent data (users, employees, candidates, comments)
# Create a free Postgres DB (Neon / Supabase / Aiven), then paste the URL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Do NOT use mysql:// — this app requires PostgreSQL.
# After setting DATABASE_URL, run once: npm run prisma:setup
#
# Without DATABASE_URL, admin user/employee create will fail with a clear error
# (memory mode no longer pretends to save — those users vanished after refresh).
