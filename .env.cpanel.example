# cPanel Node.js App — Environment Variables
# Copy each NAME=VALUE into cPanel → Setup Node.js App → Environment Variables
# Do NOT upload this file with real secrets.

# Required — login sessions (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Required
NODE_ENV=production

# HTTPS enabled on cPanel (SSL Active) — use this:
COOKIE_SECURE=true

# If testing on HTTP only (no SSL yet):
# ALLOW_INSECURE_COOKIES=true

# Optional — persistent database (contact form, uploads, saved candidates)
# cPanel MySQL: create database in cPanel → MySQL Databases, then use:
# DATABASE_URL=mysql://CPANEL_USER:PASSWORD@localhost:3306/CPANEL_DBNAME
#
# Without DATABASE_URL the app runs in DEMO mode (in-memory data).
# Or force demo mode even if DATABASE_URL is set:
CREDICUS_DEMO_MODE=true
# Demo logins still work: recruiter@credicus.com / Recruiter@123
