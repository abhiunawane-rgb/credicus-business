# cPanel Node.js App — Environment Variables
# Copy each NAME=VALUE into cPanel → Setup Node.js App → Environment Variables
# Do NOT upload this file with real secrets.

# Required — login sessions (min 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Required
NODE_ENV=production

# HTTPS enabled on cPanel (SSL Active) — use this:
COOKIE_SECURE=true

# If testing on HTTP only (no SSL yet):
# ALLOW_INSECURE_COOKIES=true

# Optional — persistent PostgreSQL database (users, candidates, catalog)
# Create a Postgres DB (Neon, Supabase, Aiven, or local), then:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Do NOT use mysql:// — this app requires PostgreSQL.
#
# Without DATABASE_URL the app runs in DEMO mode (in-memory data).
# Or force demo/memory mode ONLY when DATABASE_URL is not set:
# CREDICUS_DEMO_MODE=true
# If DATABASE_URL is a valid postgresql:// URL, the database is always used
# (even if CREDICUS_DEMO_MODE=true). This prevents lost users / 404 after create on Vercel.
